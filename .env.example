# =============================================================================
# Julie's Family / Kinflo - Environment template (copy to .env and fill in)
# See RUN_LOCALLY.md and MIGRATION_CHECKLIST.md for migration from Replit.
# =============================================================================

# --- Required to start the app ---
DATABASE_URL=postgresql://user:password@host:5432/dbname
SESSION_SECRET=generate-a-long-random-secret-hex

# --- Authentication (OIDC - any provider: Auth0, Keycloak, Google, etc.) ---
OIDC_ISSUER_URL=https://your-tenant.auth0.com
OIDC_CLIENT_ID=your-client-id
OIDC_CLIENT_SECRET=your-client-secret
# Optional: callback path (default /api/callback); full URL = BASE_URL + this
# OIDC_CALLBACK_PATH=/api/callback
# Legacy Replit: REPL_ID=, ISSUER_URL= (still supported if set)

# --- Required for payments (app throws at startup if missing) ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Public key for the donation page (browser). Get from Stripe Dashboard → Developers → API keys (pk_test_... or pk_live_...)
VITE_STRIPE_PUBLIC_KEY=pk_test_...

# --- Server ---
PORT=5000
NODE_ENV=development

# --- Email (SendGrid) ---
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@yourdomain.org

# --- Images (Cloudinary) ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Optional: AI / Gemini ---
GOOGLE_API_KEY=
GEMINI_API_KEY=

# --- Google Sheets / Calendar (direct auth; else Replit Connectors) ---
# GOOGLE_SERVICE_ACCOUNT_JSON= inline JSON or path to key file
# GOOGLE_SERVICE_ACCOUNT_KEY_PATH= path to service account JSON key file

# --- Twilio (SMS) ---
# Direct credentials (non-Replit): set these and webhook validation uses TWILIO_AUTH_TOKEN
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
# Or API key: TWILIO_API_KEY=, TWILIO_API_KEY_SECRET= (webhook needs TWILIO_AUTH_TOKEN or TWILIO_API_KEY_SECRET)
# Replit: leave unset and set REPLIT_CONNECTORS_HOSTNAME, REPL_IDENTITY or WEB_REPL_RENEWAL

# --- Object storage ---
# Set OBJECT_STORAGE_PROVIDER=s3 to use S3/R2 instead of Replit GCS
# OBJECT_STORAGE_PROVIDER=s3
# Replit (default): DEFAULT_OBJECT_STORAGE_BUCKET_ID=, PUBLIC_OBJECT_SEARCH_PATHS=, PRIVATE_OBJECT_DIR=
# S3/R2: S3_BUCKET= or R2_BUCKET=, PUBLIC_OBJECT_SEARCH_PATHS= or S3_PUBLIC_PREFIXES=, PRIVATE_OBJECT_DIR= or S3_PRIVATE_PREFIX=
# For R2: R2_ACCOUNT_ID=, R2_ACCESS_KEY_ID=, R2_SECRET_ACCESS_KEY=, R2_REGION=auto
DEFAULT_OBJECT_STORAGE_BUCKET_ID=
PUBLIC_OBJECT_SEARCH_PATHS=
PRIVATE_OBJECT_DIR=

# --- Base URL (used for auth callback, email/unsubscribe links) ---
BASE_URL=http://localhost:5000

# --- Optional: Unsubscribe ---
UNSUBSCRIBE_SECRET=
# Deprecated (use BASE_URL): REPLIT_DEV_DOMAIN=, REPLIT_DOMAINS=

# --- Optional: Other ---
DONATION_URL=https://juliesfamilylearning.org/donate
GOOGLE_PLACES_API_KEY=
LEAD_WEBHOOK_SECRET=
AI_INTEGRATIONS_OPENAI_BASE_URL=
AI_INTEGRATIONS_OPENAI_API_KEY=
