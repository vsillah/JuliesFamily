{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": false,
    "noEmit": true,
    "baseUrl": "..",
    "paths": {
      "@/*": ["./client/src/*"],
      "@shared/*": ["./shared/*"],
      "@db/*": ["./shared/*"]
    }
  },
  "include": ["./**/*", "../server/**/*", "../shared/**/*"],
  "exclude": ["node_modules"]
}
