modules = ["nodejs-20", "web", "postgresql-16"]
run = "npm run dev"
hidden = [".config", ".git", "generated-icon.png", "node_modules", "dist"]

[nix]
channel = "stable-24_05"

[deployment]
deploymentTarget = "autoscale"
build = ["npm", "run", "build"]
run = ["sh", "-c", "NODE_ENV=production PORT=5000 node dist/index.js"]

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 32945
externalPort = 3000

[[ports]]
localPort = 33297
externalPort = 8000

[[ports]]
localPort = 35129
externalPort = 5000

[[ports]]
localPort = 36469
externalPort = 3001

[[ports]]
localPort = 36641
externalPort = 6000

[[ports]]
localPort = 37447
externalPort = 6800

[[ports]]
localPort = 43011
externalPort = 3002

[[ports]]
localPort = 43213
externalPort = 8008

[[ports]]
localPort = 43871
externalPort = 5173

[[ports]]
localPort = 44719
externalPort = 3003

[[ports]]
localPort = 46711
externalPort = 4200

[env]
PORT = "5000"

[interpreter]
[interpreter.env]
REPL_HOME = "/home/runner/${REPL_SLUG}"

[workflows]
runButton = "Start application"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev"
waitForPort = 5000

[objectStorage]
defaultBucketID = "replit-objstore-be2c0cad-ba5c-42a2-95cd-fae295239b69"

[agent]
integrations = ["javascript_database:1.0.0", "javascript_log_in_with_replit:1.0.0", "javascript_object_storage:1.0.0", "javascript_gemini_ai_integrations:1.0.0", "javascript_stripe:1.0.0", "twilio:1.0.0", "google-calendar:1.0.0", "javascript_openai_ai_integrations:1.0.0", "google-sheet:1.0.0"]
